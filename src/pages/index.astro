---
import BaseHead from "@/components/BaseHead.astro";
import BlogHeader from "@/components/BlogHeader.astro";
import ContentImage from "@/components/ContentImage.astro";
import Footer from "@/components/Footer.astro";
import Gtm from "@/components/Gtm.astro";
import TextDate from "@/components/TextDate.astro";
import { getAllArticles } from "@/lib/content";
import { getContentPath } from "@/lib/routes";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/libs/constants";

const posts = (await getAllArticles()).filter((post) => post.data.lang === "ko");
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} lang="ko" />
  </head>
  <body>
    <Gtm />
    <BlogHeader lang="ko" />
    <main class="mx-auto flex w-full max-w-[920px] flex-col gap-10 px-4 py-16">
      <section class="text-center">
        <p class="text-sm font-semibold tracking-[0.3em] text-primary uppercase">Tinyrack</p>
        <h1 class="mt-4 text-4xl font-bold">타이니랙</h1>
        <p class="mx-auto mt-4 max-w-[640px] text-lg text-neutral-500">
          홈랩 하드웨어/소프트웨어 리뷰, 뉴스
        </p>
      </section>
      <section class="rounded-3xl border border-base-300 bg-base-200/50 p-6 shadow-sm">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold text-primary uppercase">Tinyrack Labs</p>
            <h2 class="mt-1 text-2xl font-bold">Products</h2>
          </div>
          <p class="text-sm text-neutral-500">작게 만들고, 매일 쓰는 도구들</p>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <a
            class="group rounded-2xl border border-base-300 bg-base-100 p-5 transition hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-md"
            href="https://dotweave.tinyrack.net"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="flex items-center justify-between gap-3 text-lg font-bold">
              Dotweave
              <i class="ri-external-link-line text-base opacity-60 transition group-hover:opacity-100"></i>
            </span>
            <p class="mt-3 text-sm leading-6 text-neutral-500">
              Git 기반으로 개발 환경 설정과 dotfiles를 여러 기기에서 동기화하는 CLI 도구입니다.
            </p>
          </a>
          <a
            class="group rounded-2xl border border-base-300 bg-base-100 p-5 transition hover:-translate-y-0.5 hover:border-secondary/40 hover:shadow-md"
            href="https://proxer.tinyrack.net"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="flex items-center justify-between gap-3 text-lg font-bold">
              Proxer
              <i class="ri-external-link-line text-base opacity-60 transition group-hover:opacity-100"></i>
            </span>
            <p class="mt-3 text-sm leading-6 text-neutral-500">
              로컬 개발 서버를 안전하게 외부에 공유하는 리버스 터널링 도구입니다.
            </p>
          </a>
        </div>
      </section>
      <section>
        <h2 class="text-2xl font-bold">Latest</h2>
        <ul class="mt-6 grid gap-8 md:grid-cols-2">
          {posts.map((post) => (
            <li>
              <a class="group flex flex-col" href={getContentPath("ko", post.data.routeSlug)}>
                {post.data.featureImage && (
                  <ContentImage
                    class="aspect-video w-full rounded-2xl object-cover transition group-hover:opacity-90"
                    src={post.data.featureImage}
                    alt={post.data.title}
                    loading="lazy"
                    widths={[480, 920]}
                    sizes="(min-width: 768px) 448px, 100vw"
                  />
                )}
                <h3 class="mt-4 text-xl font-bold group-hover:underline">
                  {post.data.title}
                </h3>
                <TextDate class="mt-2" lang="ko" date={post.data.publishedAt} />
                <p class="mt-3 line-clamp-3 text-neutral-500">{post.data.excerpt}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
