---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import BlogArticle from "@/components/BlogArticle.astro";
import TextDate from "@/components/TextDate.astro";
import {
  type AlternativeLanguageLink,
  getAlternativeLanguageLinks,
} from "@/lib/alternative-language-links";
import {
  type ArticleEntry,
  getAllArticles,
  getAllPages,
  type PageEntry,
} from "@/lib/content";
import { defaultLangCode } from "@/lib/language";

type Props = (
  | { kind: "article"; entry: ArticleEntry }
  | { kind: "page"; entry: PageEntry }
) & {
  alternativeLanguageLinks: AlternativeLanguageLink[];
};

export const getStaticPaths = (async () => {
  const [articles, pages] = await Promise.all([getAllArticles(), getAllPages()]);
  const entries = [...articles, ...pages];
  const paths = [
    ...articles
      .filter((entry) => entry.data.lang === defaultLangCode)
      .map((entry) => ({
        params: { slug: entry.data.routeSlug },
        props: {
          kind: "article",
          entry,
          alternativeLanguageLinks: getAlternativeLanguageLinks(entry, entries),
        } as Props,
      })),
    ...pages
      .filter((entry) => entry.data.lang === defaultLangCode)
      .map((entry) => ({
        params: { slug: entry.data.routeSlug },
        props: {
          kind: "page",
          entry,
          alternativeLanguageLinks: getAlternativeLanguageLinks(entry, entries),
        } as Props,
      })),
  ];
  const slugs = new Set<string>();

  for (const path of paths) {
    if (slugs.has(path.params.slug)) {
      throw new Error(`Duplicate content route slug: ${path.params.slug}`);
    }
    slugs.add(path.params.slug);
  }

  return paths;
}) satisfies GetStaticPaths;

const { kind, entry, alternativeLanguageLinks } = Astro.props as Props;
const { Content } = await render(entry);
---

<BlogArticle
  lang={entry.data.lang}
  title={entry.data.title}
  description={entry.data.excerpt || entry.data.title}
  featureImage={entry.data.featureImage}
  alternativeLanguageLinks={alternativeLanguageLinks}
>
  {kind === "article" && (
    <div slot="headerMeta" class="mt-2">
      <TextDate lang={entry.data.lang} date={(entry as ArticleEntry).data.publishedAt} />
    </div>
  )}
  <Content />
</BlogArticle>
