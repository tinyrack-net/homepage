---
import type { ImageMetadata } from "astro";
import ArticleContent from "@/components/ArticleContent.astro";
import BaseHead from "@/components/BaseHead.astro";
import BlogHeader from "@/components/BlogHeader.astro";
import ContentImage from "@/components/ContentImage.astro";
import Footer from "@/components/Footer.astro";
import { t } from "@/i18n";
import type { SupportedLanguageCodes } from "@/lib/language";
import Gtm from "./Gtm.astro";

type Props = {
  lang: SupportedLanguageCodes;
  title: string;
  description: string;
  featureImage?: ImageMetadata;
  alternativeLanguageLinks?: Array<{
    href: string;
    label: string;
    lang: SupportedLanguageCodes;
  }>;
};

const props = Astro.props as Props;
const alternativeLanguageLinks = props.alternativeLanguageLinks ?? [];
const alternativeLanguageAvailable = t(
  props.lang,
  "article.alternative-language-available",
);
---

<html lang={props.lang}>
  <head>
    <BaseHead
      title={props.title}
      description={props.description}
      ogImageUrl={props.featureImage?.src}
      lang={props.lang}
    />
  </head>

  <body>
    <Gtm />
    <BlogHeader lang={props.lang} alternativeLanguageLinks={alternativeLanguageLinks} />
    <main class="w-full max-w-full">
      <article>
        {props.featureImage && (
          <ContentImage
            class="mx-auto aspect-video w-full max-h-80 object-cover"
            src={props.featureImage}
            alt={props.title}
            loading="eager"
            widths={[720, 1280, 1600]}
            sizes="100vw"
          />
        )}
        <div class="m-auto max-w-[720px] px-4">
          <div class:list={["mt-4 flex flex-col py-4 text-center"]}>
            <h1 class="text-4xl">{props.title}</h1>
            <slot name="headerMeta" />
            {alternativeLanguageLinks.length > 0 && (
              <div class="mt-3 flex flex-wrap items-center justify-center gap-2 text-sm">
                <span class="text-neutral-500">{alternativeLanguageAvailable}</span>
                {alternativeLanguageLinks.map((link) => (
                  <a
                    class="badge badge-outline"
                    href={link.href}
                    hreflang={link.lang}
                    lang={link.lang}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
            <div class="divider"></div>
          </div>
          <ArticleContent>
            <slot />
          </ArticleContent>
          <slot name="afterContent" />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
