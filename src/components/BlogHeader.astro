---
import { t } from "@/i18n";
import { getNavigationTags } from "@/lib/content";
import {
  LOCALE_INFO,
  SUPPORTED_LANGUAGE_CODES,
  type SupportedLanguageCodes,
} from "@/lib/language";
import {
  getContentPath,
  getEquivalentLanguagePath,
  getHomePath,
  getTagPath,
} from "@/lib/routes";
import ThemeSwitcher from "./ThemeSwitcher.astro";

type Props = {
  lang: SupportedLanguageCodes;
  alternativeLanguageLinks?: Array<{
    href: string;
    label: string;
    lang: SupportedLanguageCodes;
  }>;
};

const { lang, alternativeLanguageLinks } = Astro.props;
const tags = await getNavigationTags();

const labels = {
  about: t(lang, "nav.about"),
  forum: t(lang, "nav.forum"),
  home: t(lang, "nav.home"),
  links: t(lang, "nav.links"),
  site: t(lang, "nav.site"),
  tags: t(lang, "nav.tags"),
  theme: t(lang, "theme"),
  light: t(lang, "theme.light"),
  dark: t(lang, "theme.dark"),
  auto: t(lang, "theme.auto"),
};

const languageLinks = SUPPORTED_LANGUAGE_CODES.map((targetLang) => {
  const alternativeLink = alternativeLanguageLinks?.find(
    (link) => link.lang === targetLang,
  );

  return {
    href:
      alternativeLink?.href ??
      (targetLang === lang
        ? Astro.url.pathname
        : getEquivalentLanguagePath(Astro.url.pathname, targetLang)),
    label: alternativeLink?.label ?? LOCALE_INFO[targetLang],
    lang: targetLang,
  };
});
---

<div class="drawer">
  <input id="global-drawer" type="checkbox" class="drawer-toggle" />
  <div class="fixed top-4 left-4 z-10">
    <label for="global-drawer" class="btn drawer-button btn-circle">
      <i class="ri-menu-line"></i>
    </label>
  </div>
  <div class="drawer-content">
    <slot />
  </div>
  <div class="drawer-side z-20">
    <label for="global-drawer" aria-label="close sidebar" class="drawer-overlay"
    ></label>
    <div class="bg-base-200 flex min-h-full w-60 flex-col p-4">
      <div class="flex flex-1 flex-col">
        <ul class="menu w-full p-0">
          <li class="my-2 font-bold text-neutral-600">{labels.site}</li>
          <li><a href={getHomePath(lang)}>{labels.home}</a></li>
          <li><a href={getContentPath(lang, "about")}>{labels.about}</a></li>
          <li class="my-2 font-bold text-neutral-600">{labels.tags}</li>
        </ul>
        <div class="mt-2 flex flex-wrap gap-2">
          {
            tags.map((tag) => (
              <a class="badge badge-soft" href={getTagPath(lang, tag.data.slug)}>
                {tag.data.translations[lang]?.title || tag.data.name}
              </a>
            ))
          }
        </div>
        <ul class="menu mt-2 w-full p-0">
          <li class="my-2 font-bold text-neutral-600">{labels.links}</li>
          <li>
            <a target="_blank" rel="noopener noreferrer" href="https://forum.tinyrack.net/">
              {labels.forum}
            </a>
          </li>
          <li>
            <a target="_blank" rel="noopener noreferrer" href="https://winetree94.com">
              winetree94
            </a>
          </li>
          <li>
            <a target="_blank" rel="noopener noreferrer" href="https://www.youtube.com/@tinyrack">
              YouTube
            </a>
          </li>
        </ul>
      </div>
      <div class="flex flex-col">
        <div class="divider m-0 p-0"></div>
        <ThemeSwitcher labels={labels} />
        <div class="dropdown dropdown-top">
          <button
            type="button"
            tabindex="0"
            class="btn btn-ghost w-full justify-start font-medium"
          >
            <i class="ri-translate"></i>
            <span>{LOCALE_INFO[lang]}</span>
          </button>
          <ul
            tabindex="-1"
            class="dropdown-content menu bg-base-100 rounded-box z-1 w-52 p-2 shadow-sm"
          >
            {
              languageLinks.map((link) => (
                <li>
                  <a href={link.href} hreflang={link.lang} lang={link.lang}>
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
